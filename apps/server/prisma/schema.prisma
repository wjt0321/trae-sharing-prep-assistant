// AI 任务管家 - Prisma Schema
// 数据库：SQLite（Windows 本地可运行，参考 11_后端平台数据层与AI基础设施实施清单.md）
// 说明：SQLite 不支持原生 enum/Json，统一用 String + 应用层枚举校验

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户与认证（参考 02_账号工作区与权限基础实施清单.md）
// ============================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  // 默认个人工作区
  defaultWorkspaceId String?
  defaultWorkspace    Workspace? @relation("DefaultWorkspace", fields: [defaultWorkspaceId], references: [id])
  // 时间戳
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // 关联
  workspaces   WorkspaceMember[]
  sessions     Session[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  goals        Goal[]
  comments     Comment[]
  createdTasks ExecutionTask[] @relation("TaskCreator")
  createdExports ExportRecord[] @relation("ExportCreator")
  taskJobs     TaskJob[]

  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Refresh Token 的 SHA-256 哈希（安全存储，无法反推原始 token）
  refreshTokenHash String?
  // 旧字段：明文 refresh token（已废弃，保留仅为向后兼容迁移，新 session 不再写入）
  refreshToken String?
  // 设备/UA 信息
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshTokenHash])
}

// ============================================================
// 工作区（参考 02_账号工作区与权限基础实施清单.md）
// ============================================================

model Workspace {
  id          String   @id @default(uuid())
  name        String
  // personal | team
  type        String   @default("personal")
  description String?
  ownerId     String
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  members     WorkspaceMember[]
  invites     Invite[]
  goals       Goal[]
  templates   Template[]
  knowledgeAssets KnowledgeAsset[]
  // 作为某些用户默认工作区的引用
  defaultForUsers User[] @relation("DefaultWorkspace")

  @@index([ownerId])
}

model WorkspaceMember {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // owner | admin | editor | viewer
  role         String   @default("viewer")
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Invite {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email        String
  role         String   @default("viewer")
  // 邀请 token
  token        String   @unique
  invitedById  String
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedById String?
  createdAt    DateTime @default(now())

  @@index([workspaceId])
  @@index([email])
}

// ============================================================
// 目标与规划（参考 03_目标创建器与场景识别、04_AI规划与重规划引擎）
// ============================================================

model Goal {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // 创建者
  creatorId    String
  creator      User     @relation(fields: [creatorId], references: [id])
  // 结构化输入
  // 原始目标文本（用户一句话输入，低门槛入口）
  topic        String
  // 结构化标题（AI 生成或用户编辑）
  title        String?
  // 场景类型：sharing_prep | competition | content_creation | small_project | learning | unknown
  scenarioType String?
  audience     String?
  duration     Int?
  shareDate    DateTime?
  // inform | persuade | teach | review
  goalType     String?
  preparedness String?
  // 时间约束（自然语言，如"两周内"）
  timeConstraint String?
  // 资源约束（自然语言，如"独立完成"）
  resourceConstraint String?
  // 优先级：low | medium | high | urgent
  priority     String?
  // 成功标准（自然语言描述）
  successCriteria String?
  // 当前阶段：inspiration | context | planning | executing | done | archived
  currentStage String   @default("inspiration")
  // 是否多人协作
  isCollaborative Boolean @default(false)
  // 场景标签（逗号分隔）
  sceneTags    String?
  // 场景识别快照（JSON 字符串，存储 AI 识别的完整结果，用于审计）
  scenarioSnapshot String?
  // 时间戳
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  plans        Plan[]
  tasks        ExecutionTask[]
  comments     Comment[]
  exports      ExportRecord[]
  activityEvents ActivityEvent[]

  @@index([workspaceId])
  @@index([creatorId])
  @@index([scenarioType])
  @@index([currentStage])
  @@index([deletedAt])
}

model Plan {
  id           String   @id @default(uuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  // 版本号，支持重规划
  version      Int      @default(1)
  // 是否为当前生效版本
  isActive     Boolean  @default(true)
  // 规划内容（JSON 字符串，包含 stages/checklist/insights/structureSuggestion）
  content      String
  // 规划来源：rule_engine | ai | hybrid
  source       String   @default("rule_engine")
  // 版本变更原因（首版为 null，重规划为原因，切换活跃版本为说明）
  changeReason String?
  // AI 调用记录
  aiPromptLog  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([goalId])
  @@index([isActive])
}

// ============================================================
// 执行工作台（参考 05_执行工作台与推进系统实施清单.md）
// ============================================================

model ExecutionTask {
  id           String   @id @default(uuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  // 阶段 ID（可空，表示不属于特定阶段）
  stageId      String?
  // 阶段名称（冗余存储，便于列表展示，避免每次反查 Plan.content）
  stageName    String?
  title        String
  description  String?
  // pending | in_progress | completed | cancelled | blocked | skipped
  status       String   @default("pending")
  sortOrder    Int      @default(0)
  dueDate      DateTime?
  completedAt  DateTime?
  // 阻塞原因（status=blocked 时有值）
  blockerNote  String?
  // 当前指派人（冗余存储，便于查询；变更历史见 Assignment 表）
  assigneeId   String?
  // 创建者
  creatorId    String
  creator      User     @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  statusHistory TaskStatusHistory[]
  assignments   Assignment[]

  @@index([goalId])
  @@index([status])
  @@index([creatorId])
  @@index([stageId])
  @@index([assigneeId])
  @@index([deletedAt])
  @@index([goalId, status])
}

// 任务状态变更历史（参考 05 实施清单：记录每次状态变化的时间和操作者）
model TaskStatusHistory {
  id           String   @id @default(uuid())
  taskId       String
  task         ExecutionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // 变更前状态（首次创建时为 null）
  fromStatus   String?
  // 变更后状态
  toStatus     String
  // 操作备注
  note         String?
  // 阻塞原因（toStatus=blocked 时有值）
  blockerNote  String?
  // 操作者
  operatorId   String
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([taskId])
  @@index([operatorId])
}

// ============================================================
// 协作与评论（参考 07_协作评论与版本管理实施清单.md）
// ============================================================

model Comment {
  id           String   @id @default(uuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  content      String
  // 父评论 ID（支持回复）
  parentId     String?
  // 关联的任务/阶段（可选）
  anchorType   String?
  anchorId     String?
  // 评论类型：comment | annotation（批注）
  type         String   @default("comment")
  // @提及的用户 ID（逗号分隔）
  mentions     String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([goalId])
  @@index([userId])
  @@index([anchorType, anchorId])
  @@index([type])
  @@index([goalId, parentId])
}

// 任务指派历史（参考 07 实施清单：指派变更留痕）
model Assignment {
  id           String   @id @default(uuid())
  taskId       String
  task         ExecutionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // 被指派人
  assigneeId   String
  // 指派操作者
  assignedById String
  // 指派备注
  note         String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([taskId])
  @@index([assigneeId])
}

// 活动流事件（参考 07 实施清单：谁修改了什么/完成了什么/提出了什么风险）
model ActivityEvent {
  id           String   @id @default(uuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  // 事件类型（参考 ActivityEventTypeEnum）
  type         String
  // 操作者
  actorId      String
  // 目标对象类型：task / plan / goal / comment
  targetType   String
  // 目标对象 ID
  targetId     String
  // 目标对象标题（冗余，便于展示）
  targetTitle  String?
  // 事件详情（如状态变更的 from→to）
  detail       String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([goalId])
  @@index([type])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([goalId, createdAt])
}

// ============================================================
// 模板库与知识库（参考 06_模板库知识库与资产沉淀实施清单.md）
// ============================================================

model Template {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  // 模板分类：scenario | personal | team | official
  category     String   @default("personal")
  // 关联场景类型（场景模板必填，参考 ScenarioTypeEnum）
  scenarioType String?
  // 模板内容（JSON 字符串，参考 TemplateContentDto）
  content      String
  // 是否为系统内置
  isBuiltIn    Boolean  @default(false)
  // 使用次数
  usageCount   Int      @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceId])
  @@index([category])
  @@index([scenarioType])
}

model KnowledgeAsset {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title        String
  // asset | insight | checklist | case
  type         String
  content      String
  // 标签（逗号分隔）
  tags         String?
  // 来源目标 ID（可空，表示手动创建）
  sourceGoalId String?
  // 创建者 ID（可空，系统沉淀的资产无创建者）
  creatorId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceId])
  @@index([type])
  @@index([creatorId])
}

// ============================================================
// 导出（参考 08_导出分享与交付输出实施清单.md）
// ============================================================

model ExportRecord {
  id           String   @id @default(uuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  // 导出类型：action_list | phase_plan | report_summary | review_summary | presentation_outline
  type         String
  // 导出格式：markdown | printable
  format       String
  // 导出标题
  title        String
  // Markdown 内容（直接存储，便于共享页展示）
  content      String
  // 文件路径（本地 uploads/ 下，可选）
  filePath     String?
  // 分享 token（可空，表示不分享）
  shareToken   String?  @unique
  // 分享过期时间（可空，表示永不过期）
  shareExpiresAt DateTime?
  // 是否允许下载
  allowDownload Boolean @default(true)
  // 状态：pending | succeeded | failed
  status       String   @default("succeeded")
  errorMessage String?
  // 创建者
  creatorId    String
  creator      User     @relation("ExportCreator", fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([goalId])
  @@index([shareToken])
  @@index([creatorId])
}

// ============================================================
// 通知（参考 09_通知集成与自动化实施清单.md）
// ============================================================

model Notification {
  id          String   @id @default(uuid())
  // 接收者
  userId      String
  workspaceId String
  // 通知类型（参考 NotificationTypeEnum）
  type        String
  title       String
  content     String
  // 目标对象类型：goal / task / plan / comment / workspace
  targetType  String?
  targetId    String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, readAt])
  @@index([workspaceId])
  @@index([type])
}

// ============================================================
// 异步任务调度（参考 11_后端平台数据层与AI基础设施实施清单.md）
// ============================================================

model TaskJob {
  id           String   @id @default(uuid())
  // plan_generation | replan | export | notification | ai_call | knowledge_index | cleanup
  type         String
  // queued | running | succeeded | failed | cancelled | timeout
  status       String   @default("queued")
  // 任务输入（JSON 字符串）
  payload      String
  // 任务输出（JSON 字符串）
  result       String?
  errorMessage String?
  retryCount   Int      @default(0)
  maxRetries   Int      @default(3)
  scheduledAt  DateTime @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  // 关联用户（可空，系统任务无用户）
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// AI 调用日志（参考 11_后端平台数据层与AI基础设施实施清单.md）
// ============================================================

model AiCallLog {
  id           String   @id @default(uuid())
  // 模型标识
  model        String
  // prompt 模板名
  promptName   String?
  // 输入 token 数
  inputTokens  Int      @default(0)
  // 输出 token 数
  outputTokens Int      @default(0)
  // 耗时（毫秒）
  durationMs   Int      @default(0)
  // 是否成功
  success      Boolean  @default(true)
  errorMessage String?
  // 关联任务
  taskJobId    String?
  createdAt    DateTime @default(now())

  @@index([model])
  @@index([createdAt])
}

// ============================================================
// AI 网关配置（参考 11_后端平台数据层与AI基础设施实施清单.md）
//
// 设计原则：
// - 不硬编码：URL / API Key / 模型名由网页端设置，存入数据库
// - 隐式存储：API Key 加密后存入 SQLite，不落明文配置文件
// - 不主动泄露：读取时只返回掩码，仅在实际调用时解密
// ============================================================

model AiProviderConfig {
  id         String   @id @default(uuid())
  // 服务商类型：openai / anthropic / custom
  provider   String
  // 接口地址（如 https://api.openai.com/v1）
  baseUrl    String
  // API Key 密文（AES-256-GCM 加密，格式 iv:authTag:ciphertext）
  apiKeyEnc  String
  // API Key 末尾 4 位明文（用于前端展示掩码，如 abcd）
  apiKeyHint String
  // 模型名称（如 gpt-4o-mini）
  modelName  String
  // 是否为当前活跃配置（全局唯一）
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================
// 提示词模板（Prompt Registry）
// 参考：11_后端平台数据层与AI基础设施实施清单.md §5
// 设计：
// - 按 name 索引（如 goal.detect_scenario / plan.generate）
// - 支持版本号，同一 name 只有一个 isActive=true
// - userTemplate 支持 {{var}} 占位符，由 AiGateway 渲染
// ============================================================

model PromptTemplate {
  id            String   @id @default(uuid())
  // 模板名（唯一索引，如 goal.detect_scenario）
  name          String
  // 描述（便于管理）
  description   String?
  // 系统提示词
  systemPrompt  String
  // 用户提示词模板（支持 {{var}} 占位符）
  userTemplate  String
  // 变量名列表（JSON 数组字符串，如 ["topic","scenarioType"]）
  variablesJson String   @default("[]")
  // 版本号（每次更新自增）
  version       Int      @default(1)
  // 是否为当前活跃版本（同一 name 只有一个 true）
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, version])
  @@index([name])
  @@index([isActive])
}

// ============================================================
// 审计日志（参考 12_安全监控指标与发布治理实施清单.md §1）
//
// 设计：
// - 记录关键操作（登录/配置变更/删除/导出/分享等）
// - 操作者 + 动作 + 资源 + 结果 + 上下文
// - 不记录请求体/响应体中的敏感字段（如密码、API Key）
// ============================================================

model AuditLog {
  id          String   @id @default(uuid())
  // 操作者 ID（未登录操作如 login 失败时为 null）
  actorId     String?
  // 操作者邮箱（冗余，便于审计查询）
  actorEmail  String?
  // 动作类型：login | logout | register | create | update | delete | export | share | config_change | password_change | invite | role_change
  action      String
  // 资源类型：user / workspace / goal / plan / task / comment / export / template / asset / notification / ai_config / prompt / session
  resourceType String?
  // 资源 ID
  resourceId  String?
  // 结果：success | failure
  result      String   @default("success")
  // 失败原因（result=failure 时有值）
  errorMessage String?
  // 客户端 IP
  ipAddress   String?
  // User-Agent
  userAgent   String?
  // 请求方法
  method      String?
  // 请求路径
  path        String?
  // 上下文详情（JSON 字符串，非敏感字段）
  detail      String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([result])
  @@index([createdAt])
}
