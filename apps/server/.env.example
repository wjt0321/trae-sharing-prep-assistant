# 环境变量示例文件（复制为 .env 后使用）
# ============================================================
# 本地开发：cp .env.example .env
# 生产环境：参考各变量注释，按需配置
# ============================================================

# === 服务端口 ===
PORT=4000

# === 跨域 ===
CORS_ORIGIN=http://localhost:3000

# === 数据库 ===
# 本地开发使用 SQLite；生产可切换为 PostgreSQL（需同步修改 schema.prisma provider）
DATABASE_URL="file:./dev.db"

# === JWT 鉴权 ===
# 生产环境务必使用强随机字符串（建议 ≥ 32 字节）
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# === 密码哈希 ===
# bcrypt salt rounds（生产推荐 ≥10，值越大越安全但越慢）
BCRYPT_SALT_ROUNDS=12

# === 本地文件存储 ===
UPLOAD_DIR=./uploads

# === AI 网关 ===
# mock 模式不调用真实大模型；real 模式需在 Web 界面 /app/settings/ai-config 配置
AI_GATEWAY_PROVIDER=mock
# AI 配置加密密钥（AES-256-GCM，用于加密存储在数据库中的 API Key）
# 生产环境务必使用强随机字符串（建议 >= 32 字节），且不能与 JWT_SECRET 相同
# 未配置时 AI 真实调用将被禁用（回退 mock），且无法保存 API Key 配置
AI_CONFIG_ENCRYPTION_KEY=
# 以下三项已迁移到数据库 AiProviderConfig 表（AES-256-GCM 加密存储）
# 保留为空仅为向后兼容，新配置请通过 Web 界面录入
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_MODEL=

# === 任务 Worker ===
TASK_WORKER_INTERVAL_MS=5000
TASK_WORKER_BATCH_SIZE=5
TASK_WORKER_MAX_RETRIES=3
# Session 清理轮询间隔（毫秒，默认 10 分钟）
SESSION_CLEANUP_INTERVAL_MS=600000

# === 监控与限流 ===
# 速率限制：每 IP 每分钟最大请求数
RATE_LIMIT_PER_MINUTE=120
# 认证接口（登录/注册）每 IP 每分钟最大请求数
RATE_LIMIT_AUTH_PER_MINUTE=10
# 速率限制窗口大小（毫秒，默认 60 秒）
RATE_LIMIT_WINDOW_MS=60000
# 监控统计刷写间隔（毫秒，默认 5 分钟）
MONITORING_STATS_FLUSH_MS=300000
# 磁盘空间阈值（MB）：超过警告值标记 degraded，超过不健康值标记 unhealthy
MONITORING_DISK_WARN_MB=1024
MONITORING_DISK_UNHEALTHY_MB=10240
# 任务积压阈值（排队任务数）：超过警告值标记 degraded，超过不健康值标记 unhealthy
MONITORING_JOB_BACKLOG_WARN=100
MONITORING_JOB_BACKLOG_UNHEALTHY=500
# 慢请求阈值（毫秒）：超过此值的请求计入 slowRequests 统计
MONITORING_SLOW_REQUEST_MS=1000

# === 审计日志 ===
# 审计日志保留天数（超过后由 cleanup 清理）
AUDIT_LOG_RETENTION_DAYS=90
