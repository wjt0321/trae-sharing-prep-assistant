{
  "name": "ai-task-manager",
  "private": true,
  "version": "0.1.0",
  "description": "AI 任务管家 - 从分享会筹备助手升级而来的长期产品骨架",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:web": "pnpm --filter @ai-task-manager/web dev",
    "dev:server": "pnpm --filter @ai-task-manager/server start:dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @ai-task-manager/web build",
    "build:server": "pnpm --filter @ai-task-manager/server build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:setup": "pnpm --filter @ai-task-manager/server db:setup",
    "db:migrate": "pnpm --filter @ai-task-manager/server db:migrate",
    "db:seed": "pnpm --filter @ai-task-manager/server db:seed",
    "clean": "pnpm -r exec rimraf node_modules dist .next .turbo && rimraf node_modules",
    "legacy:dev": "pnpm --filter sharing-session-planner-demo dev",
    "legacy:build": "pnpm --filter sharing-session-planner-demo build",
    "legacy:test": "pnpm --filter sharing-session-planner-demo test"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1"
  }
}
